rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email == "vk149763@gmail.com";
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.deliveryPersonId == request.auth.uid ||
        (resource.data.deliveryPersonId == null &&
         request.resource.data.deliveryPersonId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    match /bills/{billId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isAdmin() || resource.data.customerId == request.auth.uid
      );
    }

    match /customers/{customerId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /reviews/{reviewId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /laundryItems/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /deliveryItems/{itemId} {
      allow read, write: if isSignedIn() &&
        resource.data.deliveryPersonId == request.auth.uid;
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /sessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }

    match /loginLogs/{logId} {
      allow read, list: if isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isSignedIn() &&
        request.resource.data.email == request.auth.token.email;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
